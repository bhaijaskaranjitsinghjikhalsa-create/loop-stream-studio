<div class="flex min-h-screen">
  <aside class="hidden md:flex w-64 flex-col glass border-r border-border p-5 gap-2">
    <a href="/" class="flex items-center gap-3 mb-6 px-2">
      <img src="/static/logo.png" alt="JSK24Live" class="w-10 h-10" />
      <div>
        <div class="font-display font-bold text-lg leading-none bg-gradient-to-r from-accent to-primary2 bg-clip-text text-transparent">JSK24Live</div>
        <div class="text-[10px] text-muted uppercase tracking-wider">Stream Panel</div>
      </div>
    </a>
    <nav class="sidenav flex flex-col gap-1">
      <a href="/" class="<%= page==='dashboard' ? 'active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12l9-9 9 9M5 10v10h14V10"/></svg>
        Dashboard
      </a>
      <a href="/videos" class="<%= page==='videos' ? 'active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M10 9l5 3-5 3z"/></svg>
        Videos
      </a>
      <a href="/streams" class="<%= page==='streams' ? 'active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="2"/><path d="M16.24 7.76a6 6 0 010 8.49M7.76 16.24a6 6 0 010-8.49M20.49 3.51a12 12 0 010 16.97M3.51 20.49a12 12 0 010-16.97"/></svg>
        Streams
      </a>
    </nav>
    <div class="mt-auto pt-4 border-t border-border">
      <form method="POST" action="/logout">
        <button class="btn btn-ghost w-full" type="submit">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
          Logout
        </button>
      </form>
    </div>
  </aside>

  <!-- Mobile top bar -->
  <div class="md:hidden fixed top-0 inset-x-0 z-40 glass border-b border-border flex items-center justify-between px-4 py-3">
    <a href="/" class="flex items-center gap-2">
      <img src="/static/logo.png" class="w-8 h-8" />
      <span class="font-display font-bold bg-gradient-to-r from-accent to-primary2 bg-clip-text text-transparent">JSK24Live</span>
    </a>
    <div class="flex gap-1">
      <a href="/" class="px-2 py-1 text-xs <%= page==='dashboard'?'text-accent':'text-muted' %>">Home</a>
      <a href="/videos" class="px-2 py-1 text-xs <%= page==='videos'?'text-accent':'text-muted' %>">Videos</a>
      <a href="/streams" class="px-2 py-1 text-xs <%= page==='streams'?'text-accent':'text-muted' %>">Streams</a>
      <form method="POST" action="/logout" class="inline"><button class="px-2 py-1 text-xs text-muted">Exit</button></form>
    </div>
  </div>

  <main class="flex-1 md:p-8 p-4 pt-20 md:pt-8 max-w-[1400px] w-full mx-auto">
