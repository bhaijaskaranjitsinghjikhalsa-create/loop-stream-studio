<%- include('partials/head', { title: 'Login — JSK24Live' }) %>
<div class="min-h-screen flex items-center justify-center p-6">
  <div class="w-full max-w-md glass rounded-3xl p-8 shadow-2xl">
    <div class="flex flex-col items-center mb-8">
      <img src="/static/logo.png" alt="JSK24Live" class="w-24 h-24 drop-shadow-[0_0_25px_rgba(217,70,239,0.6)]" />
      <h1 class="font-display text-3xl font-bold mt-3 bg-gradient-to-r from-accent to-primary2 bg-clip-text text-transparent">JSK24Live</h1>
      <p class="text-muted text-sm mt-1">24/7 Loop Streaming Panel</p>
    </div>
    <% if (error) { %>
      <div class="bg-red-900/30 border border-red-500/40 text-red-200 text-sm rounded-xl p-3 mb-4 text-center"><%= error %></div>
    <% } %>
    <form method="POST" action="/login" class="flex flex-col gap-4">
      <div>
        <label class="text-xs uppercase tracking-wider text-muted font-semibold">Admin Key</label>
        <input class="input mt-1" type="password" name="key" autofocus required placeholder="Enter admin key" />
      </div>
      <button class="btn btn-primary w-full mt-2" type="submit">Enter Panel →</button>
    </form>
    <p class="text-center text-xs text-muted mt-6">Single admin access · No accounts</p>
  </div>
</div>
</body></html>
